#!/usr/bin/env bash
set -euo pipefail

# List globally-installed npm packages with available updates.
# Uses node (npm's own runtime) to parse JSON output.
# Output: name\tcurrent\tlatest (one per line)

npm_cmd="${PKGCTL_PM_CMD:?PKGCTL_PM_CMD must be set}"

# npm outdated -g --json exits 1 when outdated packages exist
outdated="$("$npm_cmd" outdated -g --json 2>/dev/null)" || true

if [[ -z "$outdated" || "$outdated" == "{}" ]]; then
	exit 0
fi

node -e "
  const d = JSON.parse(require('fs').readFileSync(0, 'utf8'));
  for (const [k, v] of Object.entries(d))
    if (v.current !== v.latest) console.log(k + '\t' + v.current + '\t' + v.latest);
" <<<"$outdated"
